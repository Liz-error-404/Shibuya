<script>
    function scrollCarousel(btn, direction) {
        const container = btn.parentElement;
        const slides = container.querySelector('.slides');
        const slideWidth = slides.clientWidth;
        slides.scrollBy({
            left: direction * slideWidth,
            behavior: 'smooth'
        });
    }
