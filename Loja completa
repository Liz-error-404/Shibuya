    <style>
        :root {
            --primary-bg: #fdfdfd;
            --card-bg: #ffffff;
            --text-dark: #333;
            --whatsapp-green: #25d366;
            --google-blue: #4285f4;
            --shibuya-red: #e60000;
            --footer-bg: #f8f8f8;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--primary-bg);
            margin: 0;
            color: var(--text-dark);
            line-height: 1.6;
        }

        /* DESTACADOS */
        .fantasia {
            font-weight: bold;
            background: linear-gradient(to right, #ff0000, #ff7f00, #ffff00, #00ff00, #0000ff, #4b0082, #8b00ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        .destacado-rojo {
            color: var(--shibuya-red);
            font-weight: bold;
        }

        header {
            text-align: center;
            padding: 50px 20px;
            background: white;
        }

        h1 {
            font-weight: 300;
            font-size: 1.8rem;
            color: #555;
            margin: 0;
        }

        /* GRID DE SALONES */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            padding: 20px;
        }

        @media (max-width: 992px) {
            .container { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .container { grid-template-columns: 1fr; }
        }

        /* 1. MOVIMENTAÇÃO DOS CARDS (ELEVAÇÃO) */
        .salon-card {
            background: var(--card-bg);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            border: 1px solid #eee;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease; /* Transição suave */
        }

        .salon-card:hover {
            transform: translateY(-15px); /* Eleva o card */
            box-shadow: 0 20px 40px rgba(0,0,0,0.15); /* Aumenta a sombra ao subir */
        }

        /* CARRUSEL */
        .carousel-container {
            position: relative;
            height: 280px;
            overflow: hidden;
        }

        .slides {
            display: flex;
            width: 100%;
            height: 100%;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scrollbar-width: none;
            scroll-behavior: smooth;
        }

        .slides::-webkit-scrollbar { display: none; }

        .slides img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            flex-shrink: 0;
            scroll-snap-align: start;
        }

        .carousel-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.7);
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            transition: 0.3s;
            color: #333;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .carousel-btn:hover {
            background: rgba(255, 255, 255, 0.9);
            transform: translateY(-50%) scale(1.1); /* Escala suave no botão do carrossel */
        }

        .prev-btn { left: 10px; }
        .next-btn { right: 10px; }

        .salon-info {
            padding: 25px;
            flex-grow: 1;
            text-align: center;
        }

        .salon-logo-small {
            height: 60px;
            margin-bottom: 15px;
            object-fit: contain;
        }

        .salon-info h2 { font-size: 1.3rem; margin: 10px 0; }
        .salon-info p { font-size: 0.95rem; color: #666; margin-bottom: 20px; min-height: 80px; }

        /* 3. MOVIMENTAÇÃO DOS BOTÕES DE AÇÃO (ESCALA) */
        .btn-group { display: flex; flex-direction: column; gap: 10px; }

        .btn {
            text-decoration: none !important;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease; /* Transição para escala */
        }

        .btn:hover {
            transform: scale(1.05); /* Crescimento suave */
            filter: brightness(1.1); /* Brilho leve ao passar o mouse */
        }

        .btn-wa { background-color: var(--whatsapp-green); color: white !important; }
        .btn-ig { background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%); color: white !important; }
        .btn-gm { background-color: white; color: var(--google-blue) !important; border: 1px solid var(--google-blue); }

        /* SECCIÓN WHATSAPP GENERAL */
        .general-contact {
            text-align: center;
            padding: 60px 20px;
            background: #fff;
        }

        /* 2. MOVIMENTAÇÃO DO BOTÃO GERAL (CRESCIMENTO MAIOR) */
        .btn-general-wa {
            display: inline-flex;
            background-color: var(--whatsapp-green);
            color: white !important;
            padding: 18px 45px;
            border-radius: 50px;
            text-decoration: none !important;
            font-weight: bold;
            font-size: 1.1rem;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Transição elástica */
        }

        .btn-general-wa:hover {
            transform: scale(1.15); /* Crescimento maior que os outros botões */
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.5);
            background-color: #20bd5a;
        }

        /* FOOTER */
        .site-footer {
            background-color: var(--footer-bg);
            padding: 50px 0 20px 0;
            color: #555;
            font-size: 0.9rem;
            border-top: 1px solid #eee;
