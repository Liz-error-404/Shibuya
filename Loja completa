            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            padding: 0 20px;
        }

        .footer-col { flex: 1; min-width: 250px; margin-bottom: 30px; }
        .footer-col h4 { color: #333; margin-bottom: 20px; font-size: 1.1rem; }
        .footer-logo-text { display: flex; align-items: center; gap: 10px; margin-bottom: 15px; }
        .footer-logo-text img { width: 40px; height: 40px; border-radius: 8px; }
        .footer-col ul { list-style: none; padding: 0; margin: 0; }
        .footer-col ul li { margin-bottom: 10px; }
        .footer-col ul li a { text-decoration: none; color: #666; transition: 0.3s; }
        .footer-col ul li a:hover { color: #000; padding-left: 5px; } /* Pequeno movimento no link */

        .social-icons { display: flex; gap: 15px; font-size: 1.5rem; }
        .social-icons a { color: #666; transition: 0.3s; }
        .social-icons a:hover { color: var(--whatsapp-green); transform: translateY(-5px); }

        .footer-bottom {
