<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shibuya - Encuentra tu salón</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-bg: #fdfdfd;
            --card-bg: #ffffff;
            --text-dark: #333;
            --text-light: #666;
            --whatsapp-green: #25d366;
            --google-blue: #4285f4;
            --shibuya-red: #e60000;
            --footer-bg: #f8f8f8;
            --transition: all 0.3s ease;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--primary-bg);
            margin: 0;
            color: var(--text-dark);
            line-height: 1.6;
        }

        /* TEXTO ESPECIAL */
        .fantasia {
            font-weight: bold;
            background: linear-gradient(to right, #ff0000, #ff7f00, #ffff00, #00ff00, #0000ff, #4b0082, #8b00ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
            animation: hue 5s infinite linear;
        }

        @keyframes hue {
            from { filter: hue-rotate(0deg); }
            to { filter: hue-rotate(360deg); }
        }

        .destacado-rojo {
            color: var(--shibuya-red);
            font-weight: bold;
        }

        header {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-bottom: 1px solid #f0f0f0;
        }

        .main-logo {
            max-width: 280px;
            height: auto;
            margin-bottom: 20px;
        }

        h1 {
            font-weight: 300;
            font-size: clamp(1.2rem, 5vw, 1.8rem);
            color: #555;
            margin: 0;
            max-width: 800px;
            margin: 0 auto;
        }

        /* GRID DE SALONES */
        .container {
            max-width: 1200px;
            margin: 40px auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            padding: 20px;
        }

        .salon-card {
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            border: 1px solid #eee;
            transition: var(--transition);
        }

        .salon-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        /* CARRUSEL OPTIMIZADO */
        .carousel-container {
            position: relative;
            height: 280px;
            overflow: hidden;
            background: #eee;
        }

        .slides {
            display: flex;
            width: 100%;
            height: 100%;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scrollbar-width: none; /* Firefox */
        }

        .slides::-webkit-scrollbar { display: none; } /* Chrome/Safari */

        .slides img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            flex-shrink: 0;
            scroll-snap-align: start;
        }

        .salon-info {
            padding: 30px;
            flex-grow: 1;
            text-align: center;
            display: flex;
            flex-direction: column;
        }

        .salon-logo-small {
            height: 50px;
            margin: 0 auto 15px;
            object-fit: contain;
        }

        .salon-info h2 { 
            font-size: 1.4rem; 
            margin: 10px 0; 
            color: #222;
        }

        .salon-info p { 
            font-size: 0.95rem; 
            color: var(--text-light); 
            margin-bottom: 25px; 
            min-height: 70px;
        }

        /* BOTONES */
        .btn-group { 
            display: flex; 
            flex-direction: column; 
            gap: 12px;
            margin-top: auto;
        }

        .btn {
            text-decoration: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: var(--transition);
            font-size: 0.9rem;
        }

        .btn:hover { opacity: 0.9; transform: scale(1.02); }

        .btn-wa { background-color: var(--whatsapp-green); color: white !important; }
        .btn-ig { background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%); color: white !important; }
        .btn-gm { background-color: #fff; color: var(--google-blue) !important; border: 1.5px solid var(--google-blue); }

        /* SECCIÓN CONTACTO */
        .general-contact {
            text-align: center;
            padding: 80px 20px;
            background: #fff;
        }

        .btn-general-wa {
            display: inline-flex;
            background-color: var(--whatsapp-green);
            color: white !important;
            padding: 18px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.1rem;
            box-shadow: 0 10px 20px rgba(37, 211, 102, 0.2);
            transition: var(--transition);
        }

        .btn-general-wa:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 25px rgba(37, 211, 102, 0.3);
        }

        /* FOOTER */
        .site-footer {
            background-color: var(--footer-bg);
            padding: 60px 0 20px 0;
            color: var(--text-light);
            border-top: 1px solid #eee;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 40px;
            padding: 0 20px;
        }

        .footer-col h4 {
            color: var(--text-dark);
            margin-bottom: 25px;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-logo-text {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .footer-logo-text img {
            width: 45px;
            height: 45px;
            border-radius: 10px;
        }

        .footer-col ul {
            list-style: none;
            padding: 0;
        }

        .footer-col ul li { margin-bottom: 12px; }

        .footer-col ul li a {
            text-decoration: none;
            color: var(--text-light);
            transition: var(--transition);
        }

        .footer-col ul li a:hover { color: var(--shibuya-red); padding-left: 5px; }

        .social-icons {
            display: flex;
            gap: 20px;
            font-size: 1.6rem;
        }

        .social-icons a { color: #888; transition: var(--transition); }
        .social-icons a:hover { color: var(--shibuya-red); }

        .footer-bottom {
            max-width: 1200px;
            margin: 50px auto 0;
            padding: 25px 20px;
            border-top: 1px solid #e8e8e8;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            font-size: 0.85rem;
        }

        .footer-bottom-links { display: flex; gap: 25px; }
        .footer-bottom-links a { color: #999; text-decoration: none; }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            header { padding: 40px 20px; }
            .container { gap: 20px; }
            .footer-content { text-align: center; }
            .footer-logo-text { justify-content: center; }
            .social-icons { justify-content: center; }
            .footer-bottom { flex-direction: column; text-align: center; }
        }
    </style>
</head>
